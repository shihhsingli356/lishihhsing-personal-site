---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { projects } from "@/data/projects";
---

<BaseLayout title="Projects | LiShihhsing">
  <section class="mx-auto max-w-6xl px-5 py-12 md:py-16">
    <div class="panel p-6 md:p-8">
      <p class="section-label">Projects</p>
      <h1 class="mt-4 font-display text-5xl font-semibold text-main">Project Links</h1>
      <p class="mt-5 max-w-2xl text-lg leading-8 text-soft">
        A structured index for published, in-progress, and planned projects. Placeholder content can be replaced with real links, screenshots, and project notes later.
      </p>
    </div>

    <div class="mt-5 grid gap-5 md:grid-cols-3">
      {
        projects.map((project) => (
          <article class="panel min-h-[260px] p-6">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-coral">{project.status}</p>
            <h2 class="mt-3 font-display text-2xl font-semibold text-main">{project.title}</h2>
            <p class="mt-4 text-sm leading-6 text-soft">{project.description}</p>
            <div class="mt-5 flex flex-wrap gap-2">
              {project.tech.map((item) => (
                <span class="glass-button px-3 py-1 text-xs font-semibold">{item}</span>
              ))}
            </div>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
