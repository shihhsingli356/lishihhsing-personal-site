---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { site, type Lang } from "@/data/site";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const copy = site[lang];
const { projects, projectsPage } = copy;
---

<BaseLayout title={projectsPage.title} lang={lang}>
  <section class="mx-auto max-w-6xl px-5 py-12 md:py-16">
    <div class="panel p-6 md:p-8">
      <p class="section-label">{projectsPage.label}</p>
      <h1 class="mt-4 font-display text-5xl font-semibold text-main">{projectsPage.heading}</h1>
      <p class="mt-5 max-w-2xl text-lg leading-8 text-soft">
        {projectsPage.description}
      </p>
    </div>

    <div class="mt-5 grid gap-5 md:grid-cols-3">
      {
        projects.map((project) => (
          <a class="panel block min-h-[260px] p-6 transition hover:-translate-y-1" href={project.href} target={project.href.startsWith("http") ? "_blank" : undefined} rel={project.href.startsWith("http") ? "noreferrer" : undefined}>
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-coral">{project.status}</p>
            <h2 class="mt-3 font-display text-2xl font-semibold text-main">{project.title}</h2>
            <p class="mt-4 text-sm leading-6 text-soft">{project.description}</p>
            <div class="mt-5 flex flex-wrap gap-2">
              {project.tech.map((item) => (
                <span class="glass-button px-3 py-1 text-xs font-semibold">{item}</span>
              ))}
            </div>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
